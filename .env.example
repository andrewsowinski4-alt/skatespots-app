# Copy to .env.local and fill in values (never commit .env.local).

# Canonical site URL (no trailing slash). Used for metadata, sitemap, and Open Graph.
# Production: https://skatespot.guide
NEXT_PUBLIC_SITE_URL=

# Mapbox public token (embedded in the browser bundle). Restrict by URL in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase (existing app requirements)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel Blob: add the Blob store in the Vercel project; token is injected for server routes.
